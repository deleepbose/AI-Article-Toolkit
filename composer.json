{
    "name": "deleepbose/ai-article-toolkit",
    "description": "PHP toolkit for newsroom workflows: AI headlines, summary, SEO meta, readability scoring.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Deleep\\ArticleToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Deleep\\ArticleToolkit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "find src public tests -name '*.php' -print0 | xargs -0 -n1 php -l"
    },
    "config": {
        "sort-packages": true
    }
}
